# Environment variables for local development
DATABASE_URL=postgresql://postgres:password@localhost:5432/builderpro
# Supabase connection strings that start with postgres:// are also supported.
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
RESEND_API_KEY=your_resend_api_key
INVITE_FROM_EMAIL=noreply@yourdomain.com
APP_BASE_URL=http://localhost:3500
ENABLE_LOCAL_AUTH_FALLBACK=true
SECRET_KEY=your-secret-key-change-in-production
